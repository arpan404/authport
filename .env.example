APP_NAME="AuthPort"
PORT=3000
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
DATABASE_URL="postgres://user:password@localhost:5432/authport_auth"
APPS_CONFIG_PATH="apps.yaml"

# In production: session cookies become SameSite=None; Secure, BETTER_AUTH_URL must
# be an HTTPS origin, and the auth secret must be random with at least 32 characters.
NODE_ENV="development"

# Each app owns one Postgres pool. Budget total connections as this value × app
# count × replica count. Request bodies are rejected by Bun before parsing.
DATABASE_POOL_MAX_PER_APP=5
MAX_REQUEST_BODY_SIZE=524288

# Cross-subdomain cookies are now opt-in PER APP (`cookieDomain` in apps.yaml),
# not a global setting — so one app's cookie never leaks to sibling subdomains.

# Optional. When set, app-namespaced session/cache data and atomic rate-limit
# counters are shared across instances. Falls back to per-process memory when unset.
# REDIS_URL="redis://localhost:6379"

# Optional but recommended behind a proxy/load balancer: comma-separated headers
# to resolve the real client IP so rate limits are per-client, not one shared
# bucket. Only set this if the proxy is trusted to set these headers.
# IP_ADDRESS_HEADERS="x-forwarded-for"

# Social login credentials are per-app: <APP_ID>_<PROVIDER>_CLIENT_ID / _SECRET,
# where APP_ID is the uppercased app id (non-alphanumeric -> "_").
# Enable the provider under the app's `socialProviders` in apps.yaml first.
# Register this exact redirect URI with the provider:
#   ${BETTER_AUTH_URL}/api/auth/callback/<provider>   (one URI covers all apps)
# AUTHPORT_WEB_GOOGLE_CLIENT_ID=""
# AUTHPORT_WEB_GOOGLE_CLIENT_SECRET=""
# AUTHPORT_WEB_GITHUB_CLIENT_ID=""
# AUTHPORT_WEB_GITHUB_CLIENT_SECRET=""

# Enterprise OIDC SSO credentials are per-app and per-provider:
# <APP_ID>_OIDC_<PROVIDER_ID>_CLIENT_ID / _SECRET. Enable the provider under the
# app's `oidcProviders` in apps.yaml first. Register this redirect URI with the IdP:
#   ${BETTER_AUTH_URL}/api/auth/oauth2/callback/<providerId>
# AUTHPORT_WEB_OIDC_OKTA_CLIENT_ID=""
# AUTHPORT_WEB_OIDC_OKTA_CLIENT_SECRET=""

# Enterprise SAML SSO: per-app, per-provider. The IdP signing certificate (PEM) is
# required; the SP private key (for signing AuthnRequests / decryption) is optional.
# Enable the provider under the app's `samlProviders` in apps.yaml first.
# AUTHPORT_WEB is the uppercased app id; ACME_OKTA is the uppercased providerId.
# AUTHPORT_WEB_SAML_ACME_OKTA_IDP_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# AUTHPORT_WEB_SAML_ACME_OKTA_SP_PRIVATE_KEY=""
